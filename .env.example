# Public Supabase configuration. Safe to expose to the browser with RLS enabled.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Canonical application origin used for secure authentication callbacks.
# Keep localhost for local development; use the HTTPS origin in production.
SITE_URL=http://localhost:3000

# Server-only Supabase access. Never expose this value to client code.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only salt used to hash inquiry rate-limit identifiers. Use at least 32 random characters.
INQUIRY_FINGERPRINT_SALT=

# Deferred provider configuration. Keep blank until the accounts are ready.
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
