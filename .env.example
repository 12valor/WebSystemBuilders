# Public Supabase configuration. Safe to expose to the browser with RLS enabled.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase access. Never expose this value to client code.
SUPABASE_SERVICE_ROLE_KEY=

# Deferred provider configuration. Keep blank until the accounts are ready.
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
